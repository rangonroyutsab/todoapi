{
    "info": {
        "name": "To-Do API (Django REST)",
        "description": "Elaborate Postman collection for testing the To-Do API endpoints, including pagination, success, and errors.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {"key": "base_url", "value": "http://127.0.0.1:8000/api/v1"},
        {"key": "test_username", "value": ""},
        {"key": "test_password", "value": ""},
        {"key": "access_token", "value": ""},
        {"key": "refresh_token", "value": ""},
        {"key": "task_id", "value": ""}
    ],
    "item": [
        {
            "name": "1. Authentication",
            "item": [
                {
                    "name": "Register User (Success)",
                    "request": {
                        "method": "POST",
                        "header": [{"key": "Content-Type", "value": "application/json"}],
                        "url": {"raw": "{{base_url}}/register/", "host": ["{{base_url}}"], "path": ["register", ""]},
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"username\": \"testuser_{{$randomInt}}\",\n    \"email\": \"testuser_{{$randomInt}}@example.com\",\n    \"password\": \"Password123!\"\n}"
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status code is 201', function () {",
                                    "    pm.response.to.have.status(201);",
                                    "});",
                                    "",
                                    "var data = pm.response.json();",
                                    "if(pm.response.code === 201) {",
                                    "    var reqBody = JSON.parse(pm.request.body.raw);",
                                    "    pm.collectionVariables.set('test_username', reqBody.username);",
                                    "    pm.collectionVariables.set('test_password', reqBody.password);",
                                    "}"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Register User (Error - Duplicate)",
                    "request": {
                        "method": "POST",
                        "header": [{"key": "Content-Type", "value": "application/json"}],
                        "url": {"raw": "{{base_url}}/register/", "host": ["{{base_url}}"], "path": ["register", ""]},
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"username\": \"{{test_username}}\",\n    \"email\": \"duplicate@example.com\",\n    \"password\": \"Password123!\"\n}"
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status code is 400', function () {",
                                    "    pm.response.to.have.status(400);",
                                    "});"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Login (Success)",
                    "request": {
                        "method": "POST",
                        "header": [{"key": "Content-Type", "value": "application/json"}],
                        "url": {"raw": "{{base_url}}/login/", "host": ["{{base_url}}"], "path": ["login", ""]},
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"username\": \"{{test_username}}\",\n    \"password\": \"{{test_password}}\"\n}"
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status code is 200', function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "var data = pm.response.json();",
                                    "if(pm.response.code === 200) {",
                                    "    pm.collectionVariables.set('access_token', data.access);",
                                    "    pm.collectionVariables.set('refresh_token', data.refresh);",
                                    "}"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Login (Error - Invalid)",
                    "request": {
                        "method": "POST",
                        "header": [{"key": "Content-Type", "value": "application/json"}],
                        "url": {"raw": "{{base_url}}/login/", "host": ["{{base_url}}"], "path": ["login", ""]},
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"username\": \"{{test_username}}\",\n    \"password\": \"WrongPassword!123\"\n}"
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status code is 401', function () {",
                                    "    pm.response.to.have.status(401);",
                                    "});"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Refresh Token",
                    "request": {
                        "method": "POST",
                        "header": [{"key": "Content-Type", "value": "application/json"}],
                        "url": {"raw": "{{base_url}}/token/refresh/", "host": ["{{base_url}}"], "path": ["token", "refresh", ""]},
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"refresh\": \"{{refresh_token}}\"\n}"
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status code is 200', function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "var data = pm.response.json();",
                                    "if(pm.response.code === 200) {",
                                    "    pm.collectionVariables.set('access_token', data.access);",
                                    "}"
                                ]
                            }
                        }
                    ]
                }
            ]
        },
        {
            "name": "2. Tasks - Creation & Updates",
            "item": [
                {
                    "name": "Create Task 1 (Success)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {"key": "Content-Type", "value": "application/json"},
                            {"key": "Authorization", "value": "Bearer {{access_token}}"}
                        ],
                        "url": {"raw": "{{base_url}}/tasks/", "host": ["{{base_url}}"], "path": ["tasks", ""]},
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"title\": \"Buy Groceries\",\n    \"description\": \"Milk, Eggs, Bread\",\n    \"status\": \"pending\"\n}"
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status code is 201', function () {",
                                    "    pm.response.to.have.status(201);",
                                    "});",
                                    "",
                                    "var data = pm.response.json();",
                                    "if(pm.response.code === 201) {",
                                    "    pm.collectionVariables.set('task_id', data.data.id);",
                                    "}"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Create Task 2 (Success)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {"key": "Content-Type", "value": "application/json"},
                            {"key": "Authorization", "value": "Bearer {{access_token}}"}
                        ],
                        "url": {"raw": "{{base_url}}/tasks/", "host": ["{{base_url}}"], "path": ["tasks", ""]},
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"title\": \"Clean House\",\n    \"description\": \"Living room and kitchen\",\n    \"status\": \"pending\"\n}"
                        }
                    }
                },
                {
                    "name": "Create Task 3 (Success)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {"key": "Content-Type", "value": "application/json"},
                            {"key": "Authorization", "value": "Bearer {{access_token}}"}
                        ],
                        "url": {"raw": "{{base_url}}/tasks/", "host": ["{{base_url}}"], "path": ["tasks", ""]},
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"title\": \"Read Book\",\n    \"description\": \"Read chapter 4\",\n    \"status\": \"done\"\n}"
                        }
                    }
                },
                {
                    "name": "Create Task (Error - Missing Title)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {"key": "Content-Type", "value": "application/json"},
                            {"key": "Authorization", "value": "Bearer {{access_token}}"}
                        ],
                        "url": {"raw": "{{base_url}}/tasks/", "host": ["{{base_url}}"], "path": ["tasks", ""]},
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"description\": \"This should fail because title is missing\"\n}"
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status code is 400', function () {",
                                    "    pm.response.to.have.status(400);",
                                    "});"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Create Task (Error - Unauthorized)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {"key": "Content-Type", "value": "application/json"}
                        ],
                        "url": {"raw": "{{base_url}}/tasks/", "host": ["{{base_url}}"], "path": ["tasks", ""]},
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"title\": \"Unauthorized task\"\n}"
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status code is 401', function () {",
                                    "    pm.response.to.have.status(401);",
                                    "});"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Get Task by ID (Success)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {"key": "Authorization", "value": "Bearer {{access_token}}"}
                        ],
                        "url": {"raw": "{{base_url}}/tasks/{{task_id}}/", "host": ["{{base_url}}"], "path": ["tasks", "{{task_id}}", ""]}
                    }
                },
                {
                    "name": "Update Task (Success)",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {"key": "Content-Type", "value": "application/json"},
                            {"key": "Authorization", "value": "Bearer {{access_token}}"}
                        ],
                        "url": {"raw": "{{base_url}}/tasks/{{task_id}}/", "host": ["{{base_url}}"], "path": ["tasks", "{{task_id}}", ""]},
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"title\": \"Buy Groceries Updated\",\n    \"description\": \"Milk, Eggs, Bread, Cheese\",\n    \"status\": \"done\"\n}"
                        }
                    }
                },
                {
                    "name": "Patch Task (Success)",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            {"key": "Content-Type", "value": "application/json"},
                            {"key": "Authorization", "value": "Bearer {{access_token}}"}
                        ],
                        "url": {"raw": "{{base_url}}/tasks/{{task_id}}/", "host": ["{{base_url}}"], "path": ["tasks", "{{task_id}}", ""]},
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"status\": \"pending\"\n}"
                        }
                    }
                }
            ]
        },
        {
            "name": "3. Pagination and Filtering",
            "item": [
                {
                    "name": "List Tasks (All Default)",
                    "request": {
                        "method": "GET",
                        "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
                        "url": {"raw": "{{base_url}}/tasks/", "host": ["{{base_url}}"], "path": ["tasks", ""]}
                    }
                },
                {
                    "name": "List Tasks (Page 1, Limit 2)",
                    "request": {
                        "method": "GET",
                        "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
                        "url": {
                            "raw": "{{base_url}}/tasks/?page=1&limit=2",
                            "host": ["{{base_url}}"],
                            "path": ["tasks", ""],
                            "query": [
                                {"key": "page", "value": "1"},
                                {"key": "limit", "value": "2"}
                            ]
                        }
                    }
                },
                {
                    "name": "List Tasks (Page 2, Limit 2)",
                    "request": {
                        "method": "GET",
                        "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
                        "url": {
                            "raw": "{{base_url}}/tasks/?page=2&limit=2",
                            "host": ["{{base_url}}"],
                            "path": ["tasks", ""],
                            "query": [
                                {"key": "page", "value": "2"},
                                {"key": "limit", "value": "2"}
                            ]
                        }
                    }
                },
                {
                    "name": "List Tasks (Filter Status Pending)",
                    "request": {
                        "method": "GET",
                        "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
                        "url": {
                            "raw": "{{base_url}}/tasks/?status=pending",
                            "host": ["{{base_url}}"],
                            "path": ["tasks", ""],
                            "query": [
                                {"key": "status", "value": "pending"}
                            ]
                        }
                    }
                },
                {
                    "name": "List Tasks (Sort Created At Asc)",
                    "request": {
                        "method": "GET",
                        "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
                        "url": {
                            "raw": "{{base_url}}/tasks/?sort_by=created_at&order=asc",
                            "host": ["{{base_url}}"],
                            "path": ["tasks", ""],
                            "query": [
                                {"key": "sort_by", "value": "created_at"},
                                {"key": "order", "value": "asc"}
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "4. Deletion",
            "item": [
                {
                    "name": "Delete Task (Success)",
                    "request": {
                        "method": "DELETE",
                        "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
                        "url": {"raw": "{{base_url}}/tasks/{{task_id}}/", "host": ["{{base_url}}"], "path": ["tasks", "{{task_id}}", ""]}
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status code is 200', function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Delete Task (Error - Not Found)",
                    "request": {
                        "method": "DELETE",
                        "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
                        "url": {"raw": "{{base_url}}/tasks/{{task_id}}/", "host": ["{{base_url}}"], "path": ["tasks", "{{task_id}}", ""]}
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status code is 404', function () {",
                                    "    pm.response.to.have.status(404);",
                                    "});"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Get Task by ID (Error - Not Found)",
                    "request": {
                        "method": "GET",
                        "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
                        "url": {"raw": "{{base_url}}/tasks/{{task_id}}/", "host": ["{{base_url}}"], "path": ["tasks", "{{task_id}}", ""]}
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status code is 404', function () {",
                                    "    pm.response.to.have.status(404);",
                                    "});"
                                ]
                            }
                        }
                    ]
                }
            ]
        }
    ]
}
